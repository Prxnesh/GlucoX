generator client {
  provider = "prisma-client-py"
  output   = "../app/prisma_client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskCategory {
  low
  medium
  high
}

enum RecordSource {
  prediction
  report
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  passwordHash  String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  healthRecords HealthRecord[]
  reports       ReportExtraction[]
}

model HealthRecord {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  source        RecordSource
  riskScore     Float
  category      RiskCategory
  confidence    Float?
  age           Int?
  bmi           Float?
  glucose       Float?
  bloodPressure Float?
  insulin       Float?
  familyHistory Boolean?
  hba1c         Float?
  cholesterol   Float?
  insights      Json
  recordedAt    DateTime          @default(now())
  reportId      String?           @unique
  report        ReportExtraction? @relation(fields: [reportId], references: [id])

  @@index([userId, recordedAt(sort: Desc)])
}

model ReportExtraction {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawText      String
  glucose      Float?
  hba1c        Float?
  cholesterol  Float?
  insights     Json
  createdAt    DateTime      @default(now())
  healthRecord HealthRecord?

  @@index([userId, createdAt(sort: Desc)])
}
